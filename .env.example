# .env.example - Copy to .env and fill in your values

# Database Configuration (for local development)
DATABASE_URL=jdbc:postgresql://localhost:5435/biashara360
DB_USER=biashara360
DB_PASSWORD=postgres
POSTGRES_DB=biashara360
POSTGRES_USER=biashara360
POSTGRES_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-64-character-minimum-jwt-secret-key-here-change-in-production

# M-Pesa Daraja Configuration (https://developer.safaricom.co.ke)
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORT_CODE=174379
MPESA_PASS_KEY=your_mpesa_pass_key
MPESA_ENV=sandbox
MPESA_CALLBACK_URL=https://your-domain.com/v1/payments/mpesa/callback

# CyberSource Configuration
CS_MERCHANT_ID=your_cybersource_merchant_id
CS_MERCHANT_KEY_ID=your_cybersource_key_id
CS_MERCHANT_SECRET_KEY=your_cybersource_shared_secret
CS_ENVIRONMENT=sandbox

# KRA eTIMS Configuration
KRA_ETIMS_ENV=sandbox
KRA_PIN=your_kra_pin
KRA_API_KEY=your_kra_api_key

# Social Commerce (Meta, TikTok, Claude)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
ANTHROPIC_API_KEY=your_anthropic_api_key
WEBHOOK_BASE_URL=https://your-domain.com/v1/social/webhook

# Port Configuration
PORT=8080
API_PORT=8080
DB_PORT=5435

